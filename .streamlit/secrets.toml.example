# Copy this file to `secrets.toml` (same folder) and fill in your key.
# `secrets.toml` is gitignored and is NEVER shipped to the browser — Streamlit
# injects it into the server process only. On Community Cloud / HF Spaces, set
# these in the host's Secrets UI instead of committing a file.

OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional overrides:
# OPENROUTER_MODEL = "anthropic/claude-3.5-haiku"
# APP_PUBLIC_URL   = "https://your-app.streamlit.app"
