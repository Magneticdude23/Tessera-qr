# Copy to `.env` (gitignored) for local dev, or set these in your host's secrets.
# The key is read by the FastAPI backend (server-side) and NEVER sent to the browser.

# --- FREE-BY-DEFAULT SETUP (cannot be charged) ---
# 1. Create an OpenRouter key with a $0 balance (no card, no credits).
# 2. Leave OPENROUTER_MODEL on the free router (default) or pick any ":free" slug.
# With a $0 balance + a free model, there is nothing to bill against.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# free router auto-selects a $0 model (default). Or e.g. meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=openrouter/free

# Safety: free-only mode is ON by default. The backend refuses to call any
# non-free model. To ever allow paid models you must explicitly set this to 1.
# OPENROUTER_ALLOW_PAID=0

# Hard request caps (kept below OpenRouter's free limits of 20/min, 50/day):
# LLM_PER_MIN=12
# LLM_PER_DAY=40
# LLM_GLOBAL_PER_DAY=40

# optional
# ALLOWED_ORIGINS=https://your-frontend.example.com
# APP_PUBLIC_URL=https://your-app.example.com
